# Hugging Face Inference API token (required if not using OpenAI)
# Get your token at: https://huggingface.co/settings/tokens
HUGGINGFACEHUB_API_TOKEN=hf_your_huggingface_token_here

# OpenAI API key (optional - takes precedence over Hugging Face if set)
# OPENAI_API_KEY=sk-your_openai_key_here

# Pinecone API key (required for vector retrieval)
# Get your key at: https://app.pinecone.io/
PINECONE_API_KEY=pcsk_your_pinecone_api_key_here

# Pinecone configuration (optional - defaults shown)
PINECONE_INDEX_NAME=miet-assistant-chatbot
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# Server port
PORT=10000

# JWT secret key for authentication (REQUIRED - change to a secure random string)
# Generate a secure secret: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# MongoDB connection string (REQUIRED for authentication)
# MongoDB Atlas: mongodb+srv://<username>:<password>@cluster.mongodb.net/?retryWrites=true&w=majority
# Local MongoDB: mongodb://localhost:27017
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DATABASE=miety_ai


